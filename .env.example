# Token Governor — provider configuration
#
# Copy to `.env` and fill in your real keys. `.env` is git-ignored.

# Which provider runs the classifier
# Options: anthropic | openai | ollama | mock
GOVERNOR_PROVIDER=anthropic

# API key for the chosen provider (Ollama is local; leave empty)
GOVERNOR_API_KEY=

# Override base URL — useful for proxies or compatible endpoints
# Defaults: https://api.anthropic.com  | https://api.openai.com  | http://localhost:11434
# GOVERNOR_BASE_URL=

# Which model classifies (default = best-quality model for that provider)
# Anthropic default: claude-opus-4-7
# OpenAI default:    o1
# Ollama default:    deepseek-r1:70b
# GOVERNOR_CLASSIFIER_MODEL=

# Per-tier model mapping override file (TOML)
# Default: ~/.config/token-governor/mapping.toml
# GOVERNOR_MAPPING_FILE=

# Override pricing-tabel (anders ~/.config/token-governor/pricing.toml of built-in defaults)
# GOVERNOR_PRICING_FILE=/path/to/pricing.toml

# Cache settings
# GOVERNOR_CACHE_DIR=~/.cache/token-governor
# GOVERNOR_CACHE_TTL_DAYS=30

# HTTP-server bind address (governor-http only)
# GOVERNOR_HTTP_BIND=127.0.0.1:8989

# Log level: error | warn | info | debug | trace
RUST_LOG=info
